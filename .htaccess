# Workwalaa - URL Rewrites and Redirects
# Handle organized folder structure with proper redirects

# Enable URL rewriting
RewriteEngine On

# Fix folder-relative navigation
# When a user is on /hiring/... and clicks href="careers.html", the browser requests /hiring/careers.html.
# These redirects route such requests back to the correct root pages.
RewriteRule ^hiring/index\.html$ /index.html [L,R=301]
RewriteRule ^hiring/careers\.html$ /careers.html [L,R=301]
RewriteRule ^hiring/aboutus\.html$ /aboutus.html [L,R=301]
RewriteRule ^hiring/blogs\.html$ /blogs.html [L,R=301]
RewriteRule ^hiring/interview-prep\.html$ /interview-prep.html [L,R=301]

RewriteRule ^consultancy/index\.html$ /index.html [L,R=301]
RewriteRule ^consultancy/careers\.html$ /careers.html [L,R=301]
RewriteRule ^consultancy/aboutus\.html$ /aboutus.html [L,R=301]
RewriteRule ^consultancy/blogs\.html$ /blogs.html [L,R=301]
RewriteRule ^consultancy/interview-prep\.html$ /interview-prep.html [L,R=301]

RewriteRule ^assist/index\.html$ /index.html [L,R=301]
RewriteRule ^assist/careers\.html$ /careers.html [L,R=301]
RewriteRule ^assist/aboutus\.html$ /aboutus.html [L,R=301]
RewriteRule ^assist/blogs\.html$ /blogs.html [L,R=301]
RewriteRule ^assist/interview-prep\.html$ /interview-prep.html [L,R=301]

RewriteRule ^contact/index\.html$ /index.html [L,R=301]
RewriteRule ^contact/careers\.html$ /careers.html [L,R=301]
RewriteRule ^contact/aboutus\.html$ /aboutus.html [L,R=301]
RewriteRule ^contact/blogs\.html$ /blogs.html [L,R=301]
RewriteRule ^contact/interview-prep\.html$ /interview-prep.html [L,R=301]

RewriteRule ^testimonials/index\.html$ /index.html [L,R=301]
RewriteRule ^testimonials/careers\.html$ /careers.html [L,R=301]
RewriteRule ^testimonials/aboutus\.html$ /aboutus.html [L,R=301]
RewriteRule ^testimonials/blogs\.html$ /blogs.html [L,R=301]
RewriteRule ^testimonials/interview-prep\.html$ /interview-prep.html [L,R=301]

# Redirect hiring pages
RewriteRule ^hire-employees\.html$ hiring/hire-employees.html [L,R=301]
RewriteRule ^hire-workers-in-kerala\.html$ hiring/hire-workers-in-kerala.html [L,R=301]
RewriteRule ^hire-workers-in-kochi\.html$ hiring/hire-workers-in-kochi.html [L,R=301]
RewriteRule ^hire-workers\.html$ hiring/hire-workers.html [L,R=301]
RewriteRule ^hiring-company\.html$ hiring/hiring-company.html [L,R=301]
RewriteRule ^hiring-partner-in-delhi\.html$ hiring/hiring-partner-in-delhi.html [L,R=301]
RewriteRule ^hiring-partner\.html$ hiring/hiring-partner.html [L,R=301]
RewriteRule ^recruitment-partner\.html$ hiring/recruitment-partner.html [L,R=301]
RewriteRule ^staffing-agency-in-pune\.html$ hiring/staffing-agency-in-pune.html [L,R=301]
RewriteRule ^staffing-partner\.html$ hiring/staffing-partner.html [L,R=301]
RewriteRule ^worker-hiring-platform\.html$ hiring/worker-hiring-platform.html [L,R=301]

# Redirect consultancy pages
RewriteRule ^job-consultancy\.html$ consultancy/job-consultancy.html [L,R=301]
RewriteRule ^job-consultancy-in-malappuram\.html$ consultancy/job-consultancy-in-malappuram.html [L,R=301]
RewriteRule ^recruitment-consultancy\.html$ consultancy/recruitment-consultancy.html [L,R=301]
RewriteRule ^recruitment-consultancy-in-chennai\.html$ consultancy/recruitment-consultancy-in-chennai.html [L,R=301]

# Redirect legal pages
RewriteRule ^privacy-policy\.html$ misc/privacy-policy.html [L,R=301]
RewriteRule ^terms-of-service\.html$ misc/terms-of-service.html [L,R=301]

# Handle trailing slashes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ $1.html [L,R=301]

# Redirect old root files that might still be accessed
RewriteRule ^original_index\.html$ misc/original_index.html [L,R=301]
RewriteRule ^prototype\.html$ misc/prototype.html [L,R=301]

# Ensure clean URLs (remove .html extension if desired)
# Uncomment the following lines if you want to remove .html from URLs
# RewriteRule ^(.+)\.html$ $1 [L,R=301]

# Error handling
ErrorDocument 404 /404.html

# Set proper MIME types
<FilesMatch "\.(html|htm)$">
    ForceType text/html
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval'"
</IfModule>

# Performance optimization
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg "access plus 1 month"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    SetOutputFilter DEFLATE
</IfModule>
